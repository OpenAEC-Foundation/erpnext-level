{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "foundation.openaec.y-app",
  "productName": "Y-app",
  "copyright": "Copyright © 2024 OpenAEC Foundation",
  "directories": {
    "output": "release",
    "buildResources": "build-resources"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "server/**/*.ts",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "dist",
      "to": "app/dist"
    }
  ],
  "forceCodeSigning": false,
  "win": {
    "signAndEditExecutable": false,
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ],
    "icon": "build-resources/icon.png",
    "artifactName": "Y-app-${version}-Setup.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Y-app"
  },
  "portable": {
    "artifactName": "Y-app-${version}-Portable.${ext}"
  }
}
