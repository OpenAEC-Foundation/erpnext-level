{
  "name": "erpnext-level",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/electron/main.cjs",
  "author": {
    "name": "OpenAEC Foundation",
    "url": "https://github.com/OpenAEC-Foundation"
  },
  "description": "Y-app — Multi-instance ERPNext dashboard",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx --watch server/index.ts",
    "dev:all": "concurrently \"npm run dev:server\" \"npx cross-env USE_BACKEND=true vite\"",
    "build": "tsc -b && vite build",
    "build:electron": "node scripts/build-electron.mjs",
    "build:exe": "npm run build && npm run build:electron && electron-builder --win",
    "build:portable": "npm run build && npm run build:electron && electron-builder --win portable",
    "lint": "eslint .",
    "preview": "vite preview",
    "start:server": "tsx server/index.ts",
    "electron:dev": "npm run build:electron && electron dist-electron/electron/main.cjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@types/nodemailer": "^7.0.11",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "imapflow": "^1.2.13",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.576.0",
    "mailparser": "^3.9.4",
    "nodemailer": "^8.0.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/leaflet": "^1.9.21",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.1.2",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.19.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
