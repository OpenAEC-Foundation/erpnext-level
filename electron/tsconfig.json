{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "outDir": "../dist-electron",
    "rootDir": "..",
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": ["./**/*.ts", "../server/**/*.ts"]
}
